# ═══════════════════════════════════════════════════════════════
# PhishSim Injector — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.

# ── Azure / Entra ID App Registration (REQUIRED) ─────────────
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-app-client-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# ── Simulation Defaults (OPTIONAL — configurable via UI) ─────
ATTACKER_DOMAIN=m1crosoft-alerts.com
BEC_DOMAIN=contoso-corp.com
CEO_NAME=Michael Chen, CEO
COMPANY_NAME=Contoso
LANDING_URL=https://m1crosoft-alerts.com/security/verify

# ── Security ────────────────────────────────────────────────
# Set an API key to protect all /api/ endpoints (recommended)
# Leave blank to allow unauthenticated access (local use only)
API_KEY=

# ── Server Settings ──────────────────────────────────────────
PORT=5000
FLASK_DEBUG=false
